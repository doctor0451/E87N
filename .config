# CONFIG_TARGET_zynq is not set
# CONFIG_TARGET_x86 is not set

CONFIG_TARGET_mediatek_filogic=y
# CONFIG_TARGET_mediatek_mt7622 is not set
# CONFIG_TARGET_mediatek_mt7623 is not set
# CONFIG_TARGET_mediatek_mt7629 is not set
# CONFIG_TARGET_MULTI_PROFILE is not set

# === 关键：选择 E87N 设备（如果 defconfig 中有）或使用 H5000M 基础配置 ===
# 如果 padavanonly 仓库中有 edgepi-e87n 的设备定义，请取消下行注释并注释掉 H5000M
# CONFIG_TARGET_mediatek_filogic_DEVICE_edgepi_e87n=y
CONFIG_TARGET_mediatek_filogic_DEVICE_hiveton_h5000m=y

# === 内核与系统基础 ===
CONFIG_TARGET_BOARD="mediatek"
CONFIG_TARGET_SUBTARGET="filogic"
CONFIG_TARGET_PROFILE="hiveton-h5000m"
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"
CONFIG_DEFAULT_TARGET_DEVICE="mediatek_filogic"
CONFIG_CPU_TYPE="cortex-a53"

# === 移除 WiFi 相关包（E87N 无板载 WiFi） ===
# CONFIG_PACKAGE_kmod-mt7992-firmware is not set
# CONFIG_PACKAGE_kmod-mt7992e is not set
# CONFIG_PACKAGE_kmod-mt_wifi7 is not set
# CONFIG_PACKAGE_kmod-mt_hwifi is not set
# CONFIG_PACKAGE_kmod-mt_wifi_osal is not set
# CONFIG_PACKAGE_kmod-warp is not set
# CONFIG_PACKAGE_wifi-profile is not set
# CONFIG_MTK_WIFI7_SKU_TYPE is not set

# === 添加 NVMe 支持（E87N 有两路 NVMe 插槽） ===
CONFIG_PACKAGE_kmod-nvme=y
CONFIG_PACKAGE_kmod-nvme-fabrics=y
CONFIG_PACKAGE_nvme-cli=y
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-block-devices=y

# === 文件系统支持（NVMe 硬盘常用） ===
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-fs-xfs=y

# === USB 支持（如需外接设备） ===
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_usbutils=y

# === PCIe 支持（NVMe 走 PCIe 通道） ===
CONFIG_PACKAGE_kmod-pcie-mtk=y

# === 基础网络与硬件加速 ===
CONFIG_PACKAGE_kmod-mtkhnat=y
CONFIG_PACKAGE_kmod-mtwifi=y
# CONFIG_PACKAGE_kmod-mt_wifi7 is not set  # 已在上方禁用
CONFIG_PACKAGE_kmod-mt76-connac=y
CONFIG_PACKAGE_kmod-mt76-core=y
CONFIG_PACKAGE_kmod-mt76x02-common=y
CONFIG_PACKAGE_kmod-mt7915e=y

# === 常用工具 ===
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_tmux=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_iperf3=y

# === eMMC 启动支持 ===
CONFIG_TARGET_ROOTFS_PARTSIZE=512
CONFIG_TARGET_ROOTFS_PARTNAME="rootfs"
CONFIG_GRUB_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y

# === 其他编译选项 ===
CONFIG_CCACHE=y
CONFIG_DEVEL=y
CONFIG_BUILDBOT=y
CONFIG_EXTRA_OPTIMIZATION="-Os -pipe"
CONFIG_USE_SSTRIP=y
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_KERNEL_KALLSYMS=y
