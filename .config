# This is an empty file, please overwrite it after generating the .config file with the source code

# Target Platform
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_EDGEPI_E87N=y

# CPU MT7987A 内核6.6
CONFIG_KERNEL_VERSION="6.6"
CONFIG_KERNEL_6_6=y

# Flash 8G eMMC 根分区6G
CONFIG_TARGET_ROOTFS_PARTSIZE=6144
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_SQUASHFS_LZ4=y
CONFIG_TARGET_IMAGES_GZIP=y

# 彻底关闭全部MTK WiFi7/无线驱动（本机无WiFi硬件）
# CONFIG_PACKAGE_mt_wifi7 is not set
# CONFIG_PACKAGE_mt_hwifi is not set
# CONFIG_PACKAGE_mt_wifi_osal is not set
# CONFIG_PACKAGE_warp is not set
# CONFIG_PACKAGE_wireless-regdb is not set
# CONFIG_PACKAGE_luci-app-wireless is not set
# CONFIG_PACKAGE_hostapd is not set
# CONFIG_PACKAGE_wpa-supplicant is not set

# PCIe / NVME 双硬盘插槽核心支持
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_MT7622=y
CONFIG_PCIE_MEDIATEK=y
CONFIG_PCI=y
CONFIG_PCIEPORT_SUPPORT=y
CONFIG_EFI_PARTITION=y

# 文件系统 支持NVME硬盘格式
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_SECURITY=y
CONFIG_F2FS_FS_XATTR=y
CONFIG_KMOD_FS_F2FS=y
CONFIG_KMOD_FS_NTFS3=y
CONFIG_NTFS3_MOUNT=y
CONFIG_KMOD_FS_EXT4=y

# MTK有线硬件加速 HNAT/WED
CONFIG_MTK_HNAT=y
CONFIG_MTK_WED=y
CONFIG_PACKAGE_turboacc=y

# 基础LuCI系统
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# 网络插件
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-adguardhome=y

# 存储硬盘管理
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_mountd=y
CONFIG_PACKAGE_automount=y

# 系统监控工具
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_vnstat=y

# 网络工具
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_tcpdump=y

# 精简无用无线组件
# CONFIG_PACKAGE_wireless-tools is not set
# CONFIG_PACKAGE_rpcd-mod-wireless is not set
# CONFIG_PACKAGE_wireless-regdb is not set

# 时区上海
CONFIG_TARGET_OPTIMIZATION="-O2 -march=cortex-a53"
CONFIG_ZONEINFO_SUPPORT=y
CONFIG_TIMEZONE_ASIA_SHANGHAI=y
